    "import:old-site:active:push:dry": "node scripts/import-areaimmobiliare-old-site-push.mjs --dry-run --input=data/imports/areaimmobiliare-active-strict-import.json --max-images-per-property=10",
    "import:old-site:active:push:test": "node scripts/import-areaimmobiliare-old-site-push.mjs --input=data/imports/areaimmobiliare-active-strict-import.json --limit=3 --max-images-per-property=3",
