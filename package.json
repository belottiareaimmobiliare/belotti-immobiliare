{
  "name": "belotti-immobiliare",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "import:old-site:scan": "node scripts/scan-areaimmobiliare-old-site.mjs",
    "import:old-site:scan:fast": "node scripts/scan-areaimmobiliare-old-site.mjs --max-properties=20 --max-archive-pages=20",
    "import:old-site:browser:debug": "node scripts/debug-areaimmobiliare-browser.mjs",
    "import:old-site:wayback:scan": "node scripts/scan-areaimmobiliare-wayback.mjs",
    "import:old-site:wayback:scan:fast": "node scripts/scan-areaimmobiliare-wayback.mjs --max-properties=20",
    "import:old-site:prepare": "node scripts/prepare-areaimmobiliare-import.mjs",
